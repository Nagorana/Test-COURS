# .env — Variables d'environnement
# Copiez ce fichier en .env et modifiez les valeurs

# Port du serveur (défaut : 3001)
PORT=3001

# URL du frontend React (pour CORS)
FRONTEND_URL=http://localhost:3000

# Secret JWT — CHANGEZ EN PRODUCTION !
JWT_SECRET=changez_ce_secret_en_production_svp

# Compte admin créé automatiquement au démarrage
ADMIN_EMAIL=admin@tcg.local
ADMIN_PASSWORD=Admin1234!
